{
  "name": "slop-review",
  "interface": {
    "displayName": "Slop Review"
  },
  "plugins": [
    {
      "name": "slop-review",
      "description": "Native diff review window (Monaco + Glimpse) for AI coding agents. Adds a `slop-review` skill in Codex CLI (and a /slop-review slash command in Claude Code + pi).",
      "version": "0.6.1",
      "license": "MIT",
      "category": "Engineering",
      "homepage": "https://github.com/dbachelder/slop-review",
      "keywords": [
        "diff",
        "review",
        "code-review",
        "monaco",
        "glimpse",
        "pi",
        "slop"
      ],
      "source": {
        "source": "local",
        "path": "./plugin"
      },
      "policy": {
        "installation": "AVAILABLE",
        "authentication": "ON_INSTALL"
      }
    }
  ]
}
